# ============================================================
# SYNAPSE RAG Study Assistant — environment variable template
# Copy to .env and fill real values. NEVER commit .env.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://synapse_user:change_me@localhost:5432/synapse

# --- Vector store (local folder for ChromaDB data) ---
CHROMA_PERSIST_PATH=./chroma_db

# --- JWT / Auth ---
JWT_SECRET_KEY=replace_with_a_secure_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=20
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM providers ---
GROQ_API_KEY=gsk_replace_with_your_groq_api_key
GEMINI_API_KEY=replace_with_your_google_gemini_api_key

# --- OCR ---
# Tesseract (installed on the host / in the Docker image) handles PNG/JPG and
# scanned PDFs locally for free. If it is not installed or returns no text,
# set OCR_VISION_FALLBACK_ENABLED=true to use a multimodal LLM instead. This
# requires a GEMINI_API_KEY or GROQ_API_KEY and incurs API cost, so it is OFF.
OCR_VISION_FALLBACK_ENABLED=false
OCR_LANGUAGE=eng
OCR_DPI=300

# --- CORS ---
# Include the origin the frontend is served from. In dev the backend also
# serves the static frontend at http://localhost:8000 (same-origin).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:4319,http://127.0.0.1:4319,http://localhost:8000,http://127.0.0.1:8000,https://synapse.vercel.app

# --- File storage ---
STORAGE_PATH=./storage

# --- App ---
DEBUG=false
APP_ENV=development

# --- Public base URL (used to build absolute URLs returned to the client,
#      e.g. avatar image URLs; the SPA is served from a different origin) ---
APP_BASE_URL=http://127.0.0.1:8000

# --- Upload guardrails ---
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,png,jpg,jpeg

# --- Hybrid retrieval blending weights (semantic vector + BM25 keyword) ---
# Combined score = semantic_weight * semantic_norm + bm25_weight * bm25_norm
HYBRID_SEMANTIC_WEIGHT=0.6
HYBRID_BM25_WEIGHT=0.4

# --- LLM token pricing (USD per 1M tokens) for cost logging / analytics ---
GROQ_INPUT_COST_PER_1M=0.59
GROQ_OUTPUT_COST_PER_1M=0.79
GEMINI_INPUT_COST_PER_1M=0.30
GEMINI_OUTPUT_COST_PER_1M=2.50

# --- Response cache (in-memory LRU) ---
RESPONSE_CACHE_MAX_SIZE=256
RESPONSE_CACHE_TTL_SECONDS=3600

# --- OCR vision-LLM fallback models (only used if OCR_VISION_FALLBACK_ENABLED=true) ---
OCR_VISION_MODEL=gemini-2.5-flash
OCR_VISION_MODEL_GROQ=llama-3.2-11b-vision-preview
OCR_TIMEOUT_SECONDS=60

# --- Chroma telemetry (set true to silence the non-fatal PostHog warning) ---
CHROMA_TELEMETRY_OPTOUT=true
