# Frontend build-time environment (Vite inlines these at build time).
# Copy to frontend/.env and adjust. NEVER commit the real .env (gitignored).

# Base URL the API client calls. Defaults to this if unset.
# Point it at your deployed backend's /api/v1 when building for production.
VITE_API_BASE_URL=http://localhost:8000/api/v1
